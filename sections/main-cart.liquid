<section class="cart-page">
  <h1>Your cart</h1>

  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post">
      <table class="hv-cart-table">
        <tbody>
          {% for item in cart.items %}
            <tr class="hv-cart-row">
              <td>
                {% if item.image %}
                  {{ item.image | image_url: width: 120 | image_tag: loading:'lazy', alt:item.product.title }}
                {% endif %}
              </td>
              <td>
                <strong>{{ item.product.title }}</strong>
                {% if item.variant.title != 'Default Title' %}
                  <p>{{ item.variant.title }}</p>
                {% endif %}
                <a class="hv-link-muted" href="{{ item.url_to_remove }}">Remove</a>
              </td>
              <td>
                <label for="updates_{{ item.key }}">Qty</label>
                <input class="hv-qty-input" id="updates_{{ item.key }}" type="number" name="updates[]" value="{{ item.quantity }}" min="0">
              </td>
              <td>
                <strong>{{ item.final_line_price | money }}</strong>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      <div class="panel" style="margin-top:18px;">
        <h2>Subtotal: {{ cart.total_price | money }}</h2>
        <p>Shipping and taxes are calculated at checkout.</p>
      </div>

      <div class="hv-cart-actions">
        <button class="btn secondary" type="submit" name="update" style="border:1px solid var(--border);">Update cart</button>
        <button class="btn primary" name="checkout" type="submit" style="border:0;">Checkout</button>
      </div>
    </form>
  {% else %}
    <p>Your cart is empty.</p>
    <a class="btn primary" href="{{ routes.all_products_collection_url }}">Shop now</a>
  {% endif %}
</section>

{% schema %}
{"name":"Main cart","settings":[]}
{% endschema %}
