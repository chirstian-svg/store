<section class="collection" data-hv-refresh="collection-main">

  {% render 'hv-default-sort-price-desc' %}

  {% render 'breadcrumbs', collection: collection %}

  <h1>{{ collection.title }}</h1>

  {% if collection.description != blank %}
    <p class="collection__desc">{{ collection.description }}</p>
  {% endif %}

  {% render 'hv-list-toolbar-collection', collection: collection %}

  {% if collection.products_count > 0 %}
    {% paginate collection.products by 24 %}
      <div class="product-grid" data-hv-refresh-target>
        {% for product in collection.products %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <nav class="hv-pagination" aria-label="Pagination">
          {% if paginate.previous %}
            <a class="btn secondary hv-pagination__link" href="{{ paginate.previous.url }}">← Previous</a>
          {% endif %}
          <span class="hv-pagination__status">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
          {% if paginate.next %}
            <a class="btn secondary hv-pagination__link" href="{{ paginate.next.url }}">Next →</a>
          {% endif %}
        </nav>
      {% endif %}
    {% endpaginate %}
  {% else %}
    <div class="panel" data-hv-refresh-target>
      <h2>No cards listed yet</h2>
      <p>New singles will be added as stock becomes available.</p>
      <a class="btn primary" href="{{ routes.search_url }}" style="margin-top:16px;border:0;display:inline-flex;">Search catalogue</a>
    </div>
  {% endif %}

</section>

<script src="{{ 'hv-fresh-content.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Main collection",
  "settings": []
}
{% endschema %}
