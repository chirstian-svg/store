<section class="section">
  <div class="section-head">
    <div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>
    {% if section.settings.col_all != blank %}
      <a href="{{ section.settings.col_all.url }}">View all</a>
    {% elsif collections.pokemon %}
      <a href="{{ collections.pokemon.url }}">View all</a>
    {% elsif collections.all %}
      <a href="{{ collections.all.url }}">View all</a>
    {% endif %}
  </div>

  <div class="cat-grid">
    {% if section.settings.col_all != blank %}
      {% assign url_singles = section.settings.col_all.url %}
    {% elsif collections.pokemon %}
      {% assign url_singles = collections.pokemon.url %}
    {% else %}
      {% assign url_singles = routes.all_products_collection_url %}
    {% endif %}
    {% render 'category-tile',
      label: section.settings.label_all,
      url: url_singles,
      image: section.settings.img_all,
      icon: 'cat-icon-singles.svg',
      modifier: 'singles'
    %}

    {% if section.settings.col_new != blank %}
      {% assign url_new = section.settings.col_new.url %}
    {% else %}
      {% assign url_new = routes.all_products_collection_url | append: '?sort_by=created-descending' %}
    {% endif %}
    {% render 'category-tile',
      label: section.settings.label_new,
      url: url_new,
      image: section.settings.img_new,
      icon: 'cat-icon-new.svg',
      modifier: 'new'
    %}

    {% if section.settings.col_english != blank %}
      {% assign url_english = section.settings.col_english.url %}
    {% elsif collections.english %}
      {% assign url_english = collections.english.url %}
    {% endif %}
    {% if url_english != blank %}
      {% render 'category-tile',
        label: section.settings.label_english,
        url: url_english,
        image: section.settings.img_english,
        icon: 'cat-icon-english.svg',
        modifier: 'english'
      %}
    {% endif %}

    {% if section.settings.col_japanese != blank %}
      {% assign url_japanese = section.settings.col_japanese.url %}
    {% elsif collections.japanese %}
      {% assign url_japanese = collections.japanese.url %}
    {% endif %}
    {% if url_japanese != blank %}
      {% render 'category-tile',
        label: section.settings.label_japanese,
        url: url_japanese,
        image: section.settings.img_japanese,
        icon: 'cat-icon-japanese.svg',
        modifier: 'japanese'
      %}
    {% endif %}

    {% if section.settings.col_chinese != blank %}
      {% assign url_chinese = section.settings.col_chinese.url %}
    {% elsif collections.chinese %}
      {% assign url_chinese = collections.chinese.url %}
    {% endif %}
    {% if url_chinese != blank %}
      {% render 'category-tile',
        label: section.settings.label_chinese,
        url: url_chinese,
        image: section.settings.img_chinese,
        icon: 'cat-icon-chinese.svg',
        modifier: 'chinese'
      %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Category row",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Browse singles by language and type."
    },
    {
      "type": "collection",
      "id": "col_all",
      "label": "Singles collection"
    },
    {
      "type": "image_picker",
      "id": "img_all",
      "label": "Singles image (optional override)"
    },
    {
      "type": "text",
      "id": "label_all",
      "label": "Label — Singles",
      "default": "Singles"
    },
    {
      "type": "collection",
      "id": "col_new",
      "label": "New arrivals collection (optional)"
    },
    {
      "type": "image_picker",
      "id": "img_new",
      "label": "New arrivals image (optional override)"
    },
    {
      "type": "text",
      "id": "label_new",
      "label": "Label — New Arrivals",
      "default": "New Arrivals"
    },
    {
      "type": "collection",
      "id": "col_english",
      "label": "English collection"
    },
    {
      "type": "image_picker",
      "id": "img_english",
      "label": "English image (optional override)"
    },
    {
      "type": "text",
      "id": "label_english",
      "label": "Label — English",
      "default": "English"
    },
    {
      "type": "collection",
      "id": "col_japanese",
      "label": "Japanese collection"
    },
    {
      "type": "image_picker",
      "id": "img_japanese",
      "label": "Japanese image (optional override)"
    },
    {
      "type": "text",
      "id": "label_japanese",
      "label": "Label — Japanese",
      "default": "Japanese"
    },
    {
      "type": "collection",
      "id": "col_chinese",
      "label": "Chinese collection"
    },
    {
      "type": "image_picker",
      "id": "img_chinese",
      "label": "Chinese image (optional override)"
    },
    {
      "type": "text",
      "id": "label_chinese",
      "label": "Label — Chinese",
      "default": "Chinese"
    }
  ],
  "presets": [{ "name": "Category row" }]
}
{% endschema %}
