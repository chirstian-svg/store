<section class="section">

  <div class="section-head">
    <div>
      <h2>Recently Added Singles</h2>
      <p>A small but carefully listed selection of singles.</p>
    </div>
    <a href="{{ routes.all_products_collection_url }}">View all</a>
  </div>

  {% assign selected_collection = collections[section.settings.collection] %}
  {% if selected_collection != blank and selected_collection.products_count > 0 %}
    {% assign display_collection = selected_collection %}
  {% else %}
    {% assign display_collection = collections.all %}
  {% endif %}

  {% if display_collection != blank and display_collection.products_count > 0 %}
    <div class="product-grid">
      {% for product in display_collection.products limit: 4 %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>
  {% else %}
    <div class="panel">
      <h2>No singles listed yet</h2>
      <p>New cards will show here once products are added in Shopify.</p>
      <a class="btn primary" href="{{ routes.all_products_collection_url }}" style="margin-top:16px;border:0;display:inline-flex;">Shop now</a>
    </div>
  {% endif %}

</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Optional collection",
      "info": "Leave blank to show products from All products."
    }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
