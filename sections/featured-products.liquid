<section class="section" data-hv-refresh="featured">

  <div class="section-head">
    <div>
      <h2>Recently Added Singles</h2>
      <p>A small but carefully listed selection of singles.</p>
    </div>
    {% assign view_all_collection = collections.pokemon %}
    {% if view_all_collection == blank or view_all_collection.products_count == 0 %}
      {% assign view_all_collection = collections['new-arrivals'] %}
    {% endif %}
    {% if view_all_collection == blank or view_all_collection.products_count == 0 %}
      {% if section.settings.collection != blank %}
        {% assign view_all_collection = collections[section.settings.collection] %}
      {% endif %}
    {% endif %}
    {% if view_all_collection != blank %}
      <a href="{{ view_all_collection.url }}?sort_by=created-descending">View all</a>
    {% else %}
      <a href="{{ routes.all_products_collection_url }}?sort_by=created-descending">View all</a>
    {% endif %}
  </div>

  {% comment %} Same catalogue as All Pokémon — newest first, 4 cards {% endcomment %}
  {% assign display_collection = collections.pokemon %}
  {% if display_collection == blank or display_collection.products_count == 0 %}
    {% assign display_collection = collections['new-arrivals'] %}
  {% endif %}
  {% if display_collection == blank or display_collection.products_count == 0 %}
    {% if section.settings.collection != blank %}
      {% assign display_collection = collections[section.settings.collection] %}
    {% endif %}
  {% endif %}
  {% if display_collection == blank or display_collection.products_count == 0 %}
    {% assign display_collection = collections.all %}
  {% endif %}

  {% render 'hv-home-recent-grid', collection: display_collection %}

</section>

<script src="{{ 'hv-fresh-content.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Fallback collection",
      "info": "Homepage shows the 4 newest cards from Pokémon (/collections/pokemon), then fallbacks if empty."
    }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
