<section class="product-page">
  {% render 'breadcrumbs', product: product %}

  {% assign current_variant = product.selected_or_first_available_variant %}

  <div class="product-page__grid">
    <div class="product-page__col product-page__col--media">
      <div class="product-img product-img--pdp">
        {% render 'product-zoom', product: product %}
      </div>

      <div class="product-page__meta panel">
        <h1 class="product-page__title">{{ product.title }}</h1>
        <p class="product-page__eyebrow">Real stock • Packed from New Zealand</p>

        <dl class="product-page__details">
          {% if product.type != blank %}
            <div class="product-page__detail">
              <dt>Type</dt>
              <dd>{{ product.type }}</dd>
            </div>
          {% endif %}
          {% if product.vendor != blank %}
            <div class="product-page__detail">
              <dt>Set / vendor</dt>
              <dd>{{ product.vendor }}</dd>
            </div>
          {% endif %}
          {% if product.tags.size > 0 %}
            <div class="product-page__detail">
              <dt>Tags</dt>
              <dd class="product-page__tags">
                {% for tag in product.tags limit: 8 %}
                  <span class="product-page__tag">{{ tag }}</span>
                {% endfor %}
              </dd>
            </div>
          {% endif %}
        </dl>

        {% if product.description != blank %}
          <div class="product-page__description rte">
            {{ product.description }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="product-page__col product-page__col--buy">
      <div class="panel product-page__buy-box">
        {% if product.available %}
          <div class="product-page__price-row">
            <div class="price product-page__price">{{ product.price | money }}</div>
            {% render 'collectr-badge', product: product %}
          </div>

          {% form 'product', product, class: 'product-page__form', id: 'product-form-{{ product.id }}' %}
            {% unless product.has_only_default_variant %}
              <div class="hv-form-row">
                <label for="ProductSelect-{{ product.id }}">Option</label>
                <select class="hv-select" id="ProductSelect-{{ product.id }}" name="id">
                  {% for variant in product.variants %}
                    {% if variant.available %}
                      <option
                        value="{{ variant.id }}"
                        {% if variant.id == current_variant.id %}selected{% endif %}
                      >
                        {{ variant.title }} — {{ variant.price | money }}
                      </option>
                    {% else %}
                      <option value="{{ variant.id }}" disabled>{{ variant.title }} — sold out</option>
                    {% endif %}
                  {% endfor %}
                </select>
              </div>
            {% else %}
              <input type="hidden" name="id" value="{{ current_variant.id }}">
            {% endunless %}

            <div class="hv-form-row">
              <label for="Quantity-{{ product.id }}">Quantity</label>
              <input
                class="hv-qty-input"
                id="Quantity-{{ product.id }}"
                type="number"
                name="quantity"
                value="1"
                min="1"
              >
            </div>

            <div class="product-page__actions">
              <button class="btn secondary hv-add-to-cart" type="submit" name="add">Add to cart</button>
              <button class="btn primary hv-buy-now" type="submit" name="add" data-buy-now>Buy now</button>
            </div>
          {% endform %}

          <a class="btn secondary hv-continue-shop" href="{% if collections.pokemon %}{{ collections.pokemon.url }}{% else %}{{ routes.all_products_collection_url }}{% endif %}">Continue shopping</a>
        {% else %}
          <div class="hv-sold-out">This card is currently sold out.</div>
        {% endif %}

        <div class="product-page__notes">
          <h2>Before buying</h2>
          <p>Please check condition notes and photos. Change-of-mind returns are not accepted; genuine issues are reviewed fairly. See <a href="/pages/returns">Returns</a> and <a href="/pages/card-condition">Card condition</a>.</p>
        </div>

        <div class="product-page__notes product-page__notes--shipping">
          <h2>Shipping</h2>
          <p>Packed carefully from New Zealand (sleeves, top loaders, secure mailers). Usually dispatched within <strong>1–3 business days</strong>. NZ and international rates are calculated at checkout.</p>
          <p><a href="/pages/shipping">Full shipping policy</a></p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    document.querySelectorAll('[data-buy-now]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var form = btn.closest('form');
        if (!form) return;
        var existing = form.querySelector('input[name="return_to"]');
        if (existing) existing.remove();
        var input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'return_to';
        input.value = '/checkout';
        form.appendChild(input);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Main product",
  "settings": []
}
{% endschema %}
