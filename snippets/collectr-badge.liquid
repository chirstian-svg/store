{% comment %}
  Price change badge (Collectr sync via app → custom.* metafields).
  {% render 'collectr-badge', product: product %}
{% endcomment %}

{% if product.tags contains 'collectr-managed' %}
  {% assign pct = product.metafields.custom.price_change_pct | plus: 0 %}
  {% assign market = product.metafields.custom.market_price | plus: 0 %}
  {% assign synced = product.metafields.custom.last_synced %}

  {% if synced != blank or market > 0 or pct != 0 %}
    <div class="collectr-badge collectr-badge--{% if pct > 0 %}up{% elsif pct < 0 %}down{% else %}flat{% endif %}">
      {% if pct > 0 %}
        <span class="collectr-badge__arrow" aria-hidden="true">▲</span>
        <span class="collectr-badge__pct">+{{ pct | round: 2 }}%</span>
      {% elsif pct < 0 %}
        <span class="collectr-badge__arrow" aria-hidden="true">▼</span>
        <span class="collectr-badge__pct">{{ pct | round: 2 }}%</span>
      {% else %}
        <span class="collectr-badge__arrow" aria-hidden="true">—</span>
        <span class="collectr-badge__pct">0.00%</span>
      {% endif %}
      <span class="collectr-badge__label">today</span>
    </div>
  {% endif %}
{% endif %}
