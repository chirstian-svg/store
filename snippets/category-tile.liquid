{% comment %}
  Renders a category tile with background image.
  Accepts: label, url, image (image_picker), fallback (asset filename), modifier (css class suffix)
{% endcomment %}
{% if url != blank %}
  <a
    class="category category--{{ modifier }}"
    href="{{ url }}"
    style="{% if image != blank %}--cat-bg: url('{{ image | image_url: width: 900 }}');{% elsif fallback != blank %}--cat-bg: url('{{ fallback | asset_url }}');{% endif %}"
  >
    <span class="category__shade"></span>
    <strong>{{ label }}</strong>
  </a>
{% endif %}
