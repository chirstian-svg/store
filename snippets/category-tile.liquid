{% comment %}
  Compact category tile: small icon + label.
  Accepts: label, url, icon (asset filename), modifier, image (optional theme editor override)
{% endcomment %}
{% if url != blank %}
  <a
    class="category category--{{ modifier }}"
    href="{{ url }}"
    {% if image != blank %}style="--cat-bg: url('{{ image | image_url: width: 400 }}');"{% endif %}
  >
    {% if image != blank %}
      <span class="category__thumb" aria-hidden="true"></span>
    {% elsif icon != blank %}
      <img
        class="category__icon"
        src="{{ icon | asset_url }}"
        alt=""
        width="48"
        height="48"
        loading="lazy"
      >
    {% endif %}
    <strong class="category__label">{{ label }}</strong>
  </a>
{% endif %}
